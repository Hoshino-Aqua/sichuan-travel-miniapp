.wrapper {
  background-color: rgb(251,231,226);
  width: 100vw;
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;     /* 水平居中 */
  overflow: hidden;
}

/* 图片居中显示 */
.wrapper image {
  width: 500rpx; 
  height: 500rpx;
  object-fit: contain;
  margin-bottom: 40rpx; 
}

/* 视频容器 */
.video {
  width: 80%;
  max-width: 600rpx;
  height: 300rpx; 
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 0 10rpx rgba(0,0,0,0.2);
}
.video video {
  width: 100%;
  height: 100%;
  object-fit: fill;
  border: none;
}

